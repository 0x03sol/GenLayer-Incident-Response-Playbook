# GenLayer Bradbury Testnet Deployment Config
# Copy this file to .env and fill in your values
# NEVER commit the real .env file

# Your testnet wallet private key (hex, with or without 0x prefix)
# Get one from: https://studio.genlayer.com/ (export private key)
# This wallet must have testnet GEN tokens for deployment fees
GENLAYER_PRIVATE_KEY=

# RPC endpoint for Bradbury testnet
GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com

# Chain ID (Bradbury testnet)
GENLAYER_CHAIN_ID=4221

# Optional: directory to write deployment artifacts (tx hashes, addresses)
DEPLOYMENTS_DIR=./deployments
